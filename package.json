{
  "name": "@h3l1os/mp4vault",
  "version": "2.0.0",
  "description": "Hide and extract files within MP4 video containers with AES-256-GCM encryption",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "!dist/*.map",
    "src"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mp4",
    "vault",
    "secure",
    "embed",
    "extract",
    "encryption",
    "aes-256-gcm",
    "video",
    "container"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/h3l1os/mp4vault.git"
  },
  "homepage": "https://github.com/h3l1os/mp4vault",
  "bugs": {
    "url": "https://github.com/h3l1os/mp4vault/issues"
  },
  "dependencies": {
    "debug": "^4.3.1",
    "tmp": "^0.2.1"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/node": "^25.4.0",
    "@types/tmp": "^0.2.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "author": "h3l1os",
  "license": "AGPL-3.0"
}
